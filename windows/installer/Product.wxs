<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="GuGuTalk"
           Manufacturer="GuGuTalk"
           Version="1.0.0.0"
           UpgradeCode="A1B2C3D4-5678-9ABC-DEF0-123456789ABC">

    <MajorUpgrade DowngradeErrorMessage="已安装更新版本的 GuGuTalk。" />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Feature Id="Main" Title="GuGuTalk" Level="1" Description="GuGuTalk 主程序">
      <!-- Auto-harvested files from GuGuTalk.App publish output (includes bundled models) -->
      <ComponentGroupRef Id="GuGuTalk.App.Binaries" />
      <ComponentGroupRef Id="GuGuTalk.App.Content" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="AutoStart" />
    </Feature>

    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="GuGuTalk">
        <Component Id="AutoStart" Guid="B2C3D4E5-6789-ABCD-EF01-23456789ABCD">
          <RegistryValue Root="HKCU"
                         Key="Software\Microsoft\Windows\CurrentVersion\Run"
                         Name="GuGuTalk"
                         Type="string"
                         Value="[INSTALLFOLDER]GuGuTalk.App.exe"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuDir" Name="GuGuTalk">
        <Component Id="StartMenuShortcut" Guid="C3D4E5F6-789A-BCDE-F012-3456789ABCDE">
          <Shortcut Id="StartMenuShortcut"
                    Name="GuGuTalk"
                    Target="[INSTALLFOLDER]GuGuTalk.App.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="RemoveProgramMenuDir" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\GuGuTalk" Name="installed" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>
  </Package>
</Wix>
