<Window x:Class="GuGuTalk.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GuGuTalk 设置"
        Width="680" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinWidth="560" MinHeight="400"
        Background="{StaticResource SurfacePaperBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Background="{StaticResource AquaSoftBrush}" Padding="12">
            <StackPanel>
                <TextBlock Text="GuGuTalk" FontSize="17" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20" />

                <ListBox x:Name="NavList" SelectedIndex="0" BorderThickness="0"
                         Background="Transparent" SelectionChanged="NavList_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,8" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="FontSize" Value="13" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBoxItem Content="通用" />
                    <ListBoxItem Content="输入引擎" />
                    <ListBoxItem Content="热键" />
                    <ListBoxItem Content="后处理" />
                    <ListBoxItem Content="关于" />
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <ScrollViewer Grid.Column="1" Padding="24" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ContentPanel">
                <!-- Content pages will be swapped based on navigation -->
                <TextBlock x:Name="PageTitle" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16" />

                <!-- General Page -->
                <StackPanel x:Name="GeneralPage">
                    <TextBlock Text="识别模式" FontSize="13" FontWeight="Medium" Margin="0,0,0,8" />
                    <ComboBox x:Name="ModeCombo" Width="200" HorizontalAlignment="Left" Margin="0,0,0,16">
                        <ComboBoxItem Content="本地 (sherpa-onnx)" />
                        <ComboBoxItem Content="豆包" />
                        <ComboBoxItem Content="千问" />
                    </ComboBox>

                    <TextBlock Text="外观" FontSize="13" FontWeight="Medium" Margin="0,12,0,8" />
                    <CheckBox x:Name="FollowSystemTheme" Content="跟随系统主题" IsChecked="True" />
                </StackPanel>

                <!-- Provider Page -->
                <StackPanel x:Name="ProviderPage" Visibility="Collapsed">
                    <TextBlock Text="豆包配置" FontSize="14" FontWeight="Medium" Margin="0,0,0,8" />
                    <Grid Margin="0,0,0,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="App ID" VerticalAlignment="Center" Margin="0,4" />
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="DoubaoAppId" Margin="0,4" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Access Key" VerticalAlignment="Center" Margin="0,4" />
                        <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="DoubaoAccessKey" Margin="0,4" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Resource ID" VerticalAlignment="Center" Margin="0,4" />
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="DoubaoResourceId" Margin="0,4" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Endpoint" VerticalAlignment="Center" Margin="0,4" />
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="DoubaoEndpoint" Margin="0,4" />
                    </Grid>

                    <TextBlock Text="千问配置" FontSize="14" FontWeight="Medium" Margin="0,8,0,8" />
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="API Key" VerticalAlignment="Center" Margin="0,4" />
                        <PasswordBox Grid.Row="0" Grid.Column="1" x:Name="QwenApiKey" Margin="0,4" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Model" VerticalAlignment="Center" Margin="0,4" />
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="QwenModel" Margin="0,4" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Endpoint" VerticalAlignment="Center" Margin="0,4" />
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="QwenEndpoint" Margin="0,4" />
                    </Grid>
                </StackPanel>

                <!-- Hotkey Page -->
                <StackPanel x:Name="HotkeyPage" Visibility="Collapsed">
                    <TextBlock Text="按住说话" FontSize="14" FontWeight="Medium" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <CheckBox x:Name="HoldEnabled" Content="启用" IsChecked="True" VerticalAlignment="Center" />
                        <Button x:Name="HoldHotkeyButton" Margin="16,0,0,0" Padding="12,4" Click="HoldHotkey_Click">
                            <TextBlock x:Name="HoldHotkeyDisplay" Text="Ctrl+`" FontFamily="Consolas" />
                        </Button>
                    </StackPanel>

                    <TextBlock Text="切换模式" FontSize="14" FontWeight="Medium" Margin="0,8,0,8" />
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="ToggleEnabled" Content="启用" IsChecked="True" VerticalAlignment="Center" />
                        <Button x:Name="ToggleHotkeyButton" Margin="16,0,0,0" Padding="12,4" Click="ToggleHotkey_Click">
                            <TextBlock x:Name="ToggleHotkeyDisplay" Text="Alt+Space" FontFamily="Consolas" />
                        </Button>
                    </StackPanel>
                    <TextBlock Text="点击按钮录制新的热键组合，按 Esc 取消。"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,12,0,0" />
                </StackPanel>

                <!-- Post-processing Page -->
                <StackPanel x:Name="PostProcessPage" Visibility="Collapsed">
                    <CheckBox x:Name="PostProcessEnabled" Content="启用 LLM 后处理" Margin="0,0,0,12" />

                    <TextBlock Text="标点模式" FontSize="13" FontWeight="Medium" Margin="0,0,0,8" />
                    <ComboBox x:Name="PunctuationCombo" Width="200" HorizontalAlignment="Left" Margin="0,0,0,16">
                        <ComboBoxItem Content="智能保留" />
                        <ComboBoxItem Content="去掉标点" />
                        <ComboBoxItem Content="空格代替" />
                        <ComboBoxItem Content="去掉句尾句号" />
                    </ComboBox>

                    <TextBlock Text="热词替换" FontSize="13" FontWeight="Medium" Margin="0,8,0,8" />
                    <DataGrid x:Name="HotwordGrid" AutoGenerateColumns="False"
                              CanUserAddRows="True" Height="150" Margin="0,0,0,8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="原词" Binding="{Binding Pattern}" Width="*" />
                            <DataGridTextColumn Header="替换为" Binding="{Binding Replacement}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>

                <!-- About Page -->
                <StackPanel x:Name="AboutPage" Visibility="Collapsed">
                    <TextBlock Text="GuGuTalk for Windows" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="版本 1.0.0" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16" />
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}">
                        一款 Windows 原生语音输入工具，支持本地识别和云端识别。
                    </TextBlock>
                    <TextBlock Margin="0,16,0,0" Foreground="{StaticResource TextSecondaryBrush}">
                        技术栈：C# / .NET 8 / WPF / NAudio / sherpa-onnx
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
