<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brand Colors (from DESIGN.md Aqua Chick Companion) -->
    <Color x:Key="IconAquaColor">#29B8C7</Color>
    <Color x:Key="DeepAquaColor">#0A7887</Color>
    <Color x:Key="AquaSoftColor">#D4F7FA</Color>
    <Color x:Key="IconOrangeColor">#F28C38</Color>
    <Color x:Key="ReadyGreenColor">#159B70</Color>
    <Color x:Key="SignalAmberColor">#D16E1A</Color>
    <Color x:Key="DangerRedColor">#D62E2E</Color>

    <!-- Neutral Colors -->
    <Color x:Key="TextPrimaryColor">#142226</Color>
    <Color x:Key="TextSecondaryColor">#506B6E</Color>
    <Color x:Key="BorderSubtleColor">#A0C7CC</Color>
    <Color x:Key="SurfacePaperColor">#F1FAFA</Color>
    <Color x:Key="SurfacePanelColor">#FFFCF5</Color>

    <!-- Dark Mode -->
    <Color x:Key="SurfaceDarkColor">#0E1314</Color>
    <Color x:Key="SurfacePanelDarkColor">#1A2526</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="IconAquaBrush" Color="{StaticResource IconAquaColor}" />
    <SolidColorBrush x:Key="DeepAquaBrush" Color="{StaticResource DeepAquaColor}" />
    <SolidColorBrush x:Key="AquaSoftBrush" Color="{StaticResource AquaSoftColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="SurfacePaperBrush" Color="{StaticResource SurfacePaperColor}" />
    <SolidColorBrush x:Key="SurfacePanelBrush" Color="{StaticResource SurfacePanelColor}" />
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}" />

</ResourceDictionary>
